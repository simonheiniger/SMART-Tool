# Site-spezifische Umgebung fuer den Pi. Kopieren nach: deploy/standby-tool.env
#   cp deploy/standby-tool.env.example deploy/standby-tool.env
# Danach Werte anpassen. Die echte Datei ist per .gitignore ausgeschlossen.

# --- Echter Shelly Gen4 statt Mock ---
SHELLY_BASE_URL=http://192.168.1.50
# SHELLY_ID=0
# SHELLY_USERNAME=
# SHELLY_PASSWORD=

# --- Anwesenheit real per Netzwerk (nicht simuliert) ---
PRESENCE_MOCK=0
PRESENCE_TARGET=192.168.1.100   # IP/Hostname des Smartphones

# --- Optional: Standardwerte ---
# DEVICE_NAME=Fernseher
# STANDBY_W=5
# PRICE_PER_KWH=0.30
# OFF_DELAY_S=180
